# build dirs
_build/
build/
out/

# libpq client pieces (downloaded/extracted by CMake at configure on Windows;
# system package on POSIX)
pgsql/
postgresql-*-windows-x64-binaries.zip

# local dev server data
_pgdata/

# native module artifacts
*.shared_module
*.lib
*.exp
*.pdb
*.ilk
*.obj

# libpq runtime DLLs (copied beside the .shared_module by the build)
*.dll

# generated docs (regenerated by utils/postgres2rst.das in CI)
doc/source/stdlib/generated/
doc/build/
doc/source/__pycache__/

# runtime / scratch
*.log
_smoke_*.das
